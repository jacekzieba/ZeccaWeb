NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_FAKE_SYNC=

# Beta waitlist backed by Airtable. Keep disabled unless the Airtable base,
# table, and token are configured in the target environment.
NEXT_PUBLIC_BETA_WAITLIST_ENABLED=
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_WAITLIST_TABLE_ID=

# Optional overrides if Airtable field names differ from the defaults used by
# app/api/beta-waitlist/route.ts: Email, Consent, Source, Created At, User Agent.
AIRTABLE_WAITLIST_EMAIL_FIELD=
AIRTABLE_WAITLIST_CONSENT_FIELD=
AIRTABLE_WAITLIST_SOURCE_FIELD=
AIRTABLE_WAITLIST_CREATED_AT_FIELD=
AIRTABLE_WAITLIST_USER_AGENT_FIELD=

# TelemetryDeck (shared app across iOS/macOS/web). Leave empty in dev to disable
# (no app ID ⇒ no signals). Production value: 0B524246-D7D6-4A77-9685-129DE5604015
NEXT_PUBLIC_TELEMETRYDECK_APP_ID=
# Optional: app version / build stamped onto every signal.
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_BUILD_SHA=
# Optional kill switch: set to 1 to force-disable telemetry regardless of consent.
NEXT_PUBLIC_TELEMETRY_DISABLED=
